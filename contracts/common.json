{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-insurance/contracts/common.json",
  "title": "Common Definitions",
  "description": "Reusable definitions for all Source Intelligence contracts",
  "definitions": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the contract schema"
    },
    "run_id": {
      "type": "string",
      "pattern": "^si_(\\d{8}T\\d{6}Z|job_\\d+)$",
      "description": "Run identifier: si_<UTC timestamp> or si_job_<Databricks job run id>"
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of the artifact produced"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$",
      "description": "Stable governed knowledge-pack identifier"
    },
    "pack_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Immutable semantic version of a knowledge pack"
    },
    "content_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 fingerprint of canonical artifact content"
    },
    "effective_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 calendar date"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "Standard",
        "Specialized",
        "Source extension",
        "Candidate",
        "Unresolved"
      ],
      "description": "Governed lifecycle classification for knowledge"
    },
    "knowledge_owner_role": {
      "type": "string",
      "enum": [
        "DATA_ARCHITECT",
        "DOMAIN_STEWARD",
        "PRIVACY_STEWARD",
        "PLATFORM_ENGINEER",
        "EVALUATION_OWNER",
        "SPONSOR"
      ]
    },
    "evidence_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Exact references to authorized supporting evidence"
    },
    "knowledge_scope": {
      "type": "object",
      "properties": {
        "product": {"type": "string"},
        "module": {"type": "string"},
        "product_version": {"$ref": "#/definitions/pack_version"},
        "domain": {"$ref": "#/definitions/domain"},
        "line_of_business": {"type": "string"}
      },
      "required": [
        "product",
        "module",
        "product_version",
        "domain",
        "line_of_business"
      ],
      "additionalProperties": false
    },
    "knowledge_provenance": {
      "type": "object",
      "properties": {
        "pack_id": {"$ref": "#/definitions/pack_id"},
        "pack_version": {"$ref": "#/definitions/pack_version"},
        "effective_from": {"$ref": "#/definitions/effective_date"},
        "effective_to": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "approval_state": {"$ref": "#/definitions/approval_state"},
        "owner_role": {"$ref": "#/definitions/knowledge_owner_role"},
        "evidence_references": {"$ref": "#/definitions/evidence_references"},
        "content_fingerprint": {"$ref": "#/definitions/content_fingerprint"},
        "created_at": {"$ref": "#/definitions/timestamp_utc"}
      },
      "required": [
        "pack_id",
        "pack_version",
        "effective_from",
        "effective_to",
        "approval_state",
        "owner_role",
        "evidence_references",
        "content_fingerprint",
        "created_at"
      ],
      "additionalProperties": false
    },
    "engagement_id": {
      "type": "string",
      "description": "Engagement or pilot identifier"
    },
    "source_system": {
      "type": "string",
      "description": "Source system name"
    },
    "source_table": {
      "type": "string",
      "description": "Source table name"
    },
    "source_column": {
      "type": "string",
      "description": "Source column name"
    },
    "ordinal_position": {
      "type": "integer",
      "minimum": 1,
      "description": "Column position in the source table"
    },
    "physical_type": {
      "type": "string",
      "description": "PySpark data type string representation"
    },
    "nullable": {
      "type": "boolean",
      "description": "Whether the column accepts null values"
    },
    "observed_or_inferred": {
      "type": "string",
      "enum": [
        "OBSERVED",
        "INFERRED"
      ],
      "description": "Whether the value was directly observed or inferred"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Overall confidence score (0.0 to 1.0)"
    },
    "confidence_component": {
      "type": "object",
      "properties": {
        "value": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0,
          "maximum": 1.0
        },
        "availability": {
          "type": "string",
          "enum": [
            "AVAILABLE",
            "NOT_AVAILABLE",
            "CONTRADICTED"
          ]
        },
        "evidence_reference": {
          "type": [
            "string",
            "null"
          ]
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      },
      "required": [
        "value",
        "availability",
        "weight"
      ],
      "additionalProperties": false
    },
    "evidence_coverage": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Available weight divided by total weight"
    },
    "privacy_class": {
      "type": "string",
      "enum": [
        "INTERNAL",
        "PERSONAL_DATA",
        "SENSITIVE"
      ],
      "description": "Privacy classification"
    },
    "approval_state": {
      "type": "string",
      "enum": [
        "PROPOSED",
        "APPROVED",
        "MODIFIED",
        "REJECTED",
        "DEFERRED"
      ],
      "description": "Approval state of the recommendation"
    },
    "reviewer_role": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "DATA_ARCHITECT",
        "DOMAIN_STEWARD",
        "PRIVACY_STEWARD"
      ],
      "description": "Assigned reviewer role"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "key_role": {
      "type": "string",
      "enum": [
        "PRIMARY_KEY_CANDIDATE",
        "FOREIGN_KEY_CANDIDATE",
        "NON_KEY"
      ],
      "description": "Inferred key role"
    },
    "domain": {
      "type": "string",
      "enum": [
        "Policy",
        "Claims",
        "Shared",
        "Billing",
        "Product",
        "Coverage",
        "Reference Data",
        "Risk",
        "Document",
        "Motor",
        "Home",
        "CommercialProperty",
        "Pensions"
      ],
      "description": "Insurance domain classification"
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-insurance/contracts/knowledge_concept.json",
  "title": "Knowledge Concept",
  "description": "Versioned P&C ontology concept with governed lifecycle and provenance",
  "type": "object",
  "properties": {
    "schema_version": {"$ref": "common.json#/definitions/schema_version"},
    "concept_id": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9_]*\\.[A-Z][A-Za-z0-9_]*$"},
    "concept_name": {"type": "string"},
    "definition": {"type": "string"},
    "concept_type": {
      "type": "string",
      "enum": [
        "ENTITY",
        "ATTRIBUTE",
        "REFERENCE",
        "EVENT",
        "MEASURE",
        "TECHNICAL",
        "CODE",
        "DATE",
        "STATUS"
      ]
    },
    "lifecycle_state": {"$ref": "common.json#/definitions/lifecycle_state"},
    "privacy_class": {"$ref": "common.json#/definitions/privacy_class"},
    "synonyms": {"type": "array", "items": {"type": "string"}},
    "physical_name_variants": {"type": "array", "items": {"type": "string"}},
    "lob_applicability": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "temporality": {"type": "string", "enum": ["STATIC", "SCD2", "EVENT", "SNAPSHOT"]},
    "typical_attributes": {"type": "array", "items": {"type": "string"}},
    "status_values": {"type": "array", "items": {"type": "string"}},
    "steward_notes": {"type": "string"},
    "scope": {"$ref": "common.json#/definitions/knowledge_scope"},
    "provenance": {"$ref": "common.json#/definitions/knowledge_provenance"}
  },
  "required": [
    "schema_version",
    "concept_id",
    "concept_name",
    "definition",
    "concept_type",
    "lifecycle_state",
    "privacy_class",
    "synonyms",
    "physical_name_variants",
    "lob_applicability",
    "temporality",
    "typical_attributes",
    "status_values",
    "steward_notes",
    "scope",
    "provenance"
  ],
  "additionalProperties": false
}

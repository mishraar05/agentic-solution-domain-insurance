{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-insurance/contracts/knowledge_pack_version.json",
  "title": "Knowledge Pack Version",
  "description": "Immutable identity, scope, status, and provenance for one knowledge-pack version",
  "type": "object",
  "properties": {
    "schema_version": {"$ref": "common.json#/definitions/schema_version"},
    "pack_id": {"$ref": "common.json#/definitions/pack_id"},
    "pack_version": {"$ref": "common.json#/definitions/pack_version"},
    "pack_status": {"type": "string", "enum": ["DEVELOPMENT", "PUBLISHED", "RETIRED"]},
    "parent_pack_version": {"type": ["string", "null"], "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "description": {"type": "string"},
    "changelog": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "scope": {"$ref": "common.json#/definitions/knowledge_scope"},
    "provenance": {"$ref": "common.json#/definitions/knowledge_provenance"}
  },
  "required": [
    "schema_version",
    "pack_id",
    "pack_version",
    "pack_status",
    "parent_pack_version",
    "description",
    "changelog",
    "scope",
    "provenance"
  ],
  "additionalProperties": false
}

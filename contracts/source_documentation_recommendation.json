{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-insurance/contracts/source_documentation_recommendation.json",
  "title": "Source Documentation Recommendation",
  "description": "LLM-assisted, non-authoritative source-column description and business-glossary proposal",
  "type": "object",
  "properties": {
    "schema_version": {"$ref": "common.json#/definitions/schema_version"},
    "recommendation_id": {"type": "string", "pattern": "^si_doc_[a-f0-9]{32}$"},
    "run_id": {"$ref": "common.json#/definitions/run_id"},
    "artifact_version": {"$ref": "common.json#/definitions/artifact_version"},
    "engagement_id": {"$ref": "common.json#/definitions/engagement_id"},
    "source_system": {"$ref": "common.json#/definitions/source_system"},
    "source_table": {"$ref": "common.json#/definitions/source_table"},
    "source_column": {"$ref": "common.json#/definitions/source_column"},
    "context_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidence_references": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "generation_status": {"type": "string", "enum": ["PROPOSED", "UNRESOLVED"]},
    "proposed_column_description": {"type": ["string", "null"]},
    "proposed_glossary_term": {"type": ["string", "null"]},
    "proposed_glossary_definition": {"type": ["string", "null"]},
    "proposed_glossary_concept_id": {"type": ["string", "null"]},
    "resolution_reason": {"type": "string"},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "contradictions": {"type": "array", "items": {"type": "string"}},
    "prompt_version": {"$ref": "common.json#/definitions/artifact_version"},
    "model_endpoint": {"type": "string"},
    "approval_state": {"type": "string", "const": "PROPOSED"},
    "reviewer_role": {"type": "string", "const": "DOMAIN_STEWARD"},
    "created_at": {"$ref": "common.json#/definitions/timestamp_utc"}
  },
  "required": [
    "schema_version",
    "recommendation_id",
    "run_id",
    "artifact_version",
    "engagement_id",
    "source_system",
    "source_table",
    "source_column",
    "context_fingerprint",
    "evidence_references",
    "generation_status",
    "proposed_column_description",
    "proposed_glossary_term",
    "proposed_glossary_definition",
    "proposed_glossary_concept_id",
    "resolution_reason",
    "assumptions",
    "contradictions",
    "prompt_version",
    "model_endpoint",
    "approval_state",
    "reviewer_role",
    "created_at"
  ],
  "additionalProperties": false
}

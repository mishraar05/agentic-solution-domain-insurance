{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-insurance/contracts/ontology_relationship.json",
  "title": "Ontology Relationship",
  "description": "Typed relationship between two concepts in one exact knowledge scope",
  "type": "object",
  "properties": {
    "schema_version": {"$ref": "common.json#/definitions/schema_version"},
    "relationship_id": {"type": "string", "pattern": "^REL\\.[A-Za-z0-9_.-]+$"},
    "source_concept_id": {"type": "string"},
    "target_concept_id": {"type": "string"},
    "relationship_type": {
      "type": "string",
      "enum": [
        "BELONGS_TO",
        "COVERS",
        "DERIVES_FROM",
        "DESCRIBES",
        "GROUPS",
        "HAS",
        "IDENTIFIES",
        "INSURES",
        "IS_A",
        "MEASURES",
        "PRECEDES",
        "PRODUCED_BY",
        "REDUCES",
        "REFERENCES"
      ]
    },
    "source_relationship_type": {"type": "string"},
    "source_cardinality": {"type": "string", "enum": ["ONE", "ZERO_OR_ONE", "ONE_OR_MORE", "ZERO_OR_MORE"]},
    "target_cardinality": {"type": "string", "enum": ["ONE", "ZERO_OR_ONE", "ONE_OR_MORE", "ZERO_OR_MORE"]},
    "definition": {"type": "string"},
    "lifecycle_state": {"$ref": "common.json#/definitions/lifecycle_state"},
    "scope": {"$ref": "common.json#/definitions/knowledge_scope"},
    "provenance": {"$ref": "common.json#/definitions/knowledge_provenance"}
  },
  "required": [
    "schema_version",
    "relationship_id",
    "source_concept_id",
    "target_concept_id",
    "relationship_type",
    "source_relationship_type",
    "source_cardinality",
    "target_cardinality",
    "definition",
    "lifecycle_state",
    "scope",
    "provenance"
  ],
  "additionalProperties": false
}

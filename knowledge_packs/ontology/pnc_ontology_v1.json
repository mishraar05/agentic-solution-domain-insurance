   "ENTITY",
   "ATTRIBUTE",
   "MEASURE",
   "STATUS",
   "DATE",
   "CODE"
  ],
  "privacy_sensitivity": [
   "NONE",
   "INDIRECT",
   "DIRECT"
  ],
  "temporality": {
   "STATIC": "slowly changing reference",
   "SCD2": "track full history in Silver",
   "EVENT": "immutable event/transaction grain",
   "SNAPSHOT": "point-in-time balance; requires as-of snapshots"
  }
 },
